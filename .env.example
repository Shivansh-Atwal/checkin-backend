# Server Settings
PORT=5000
NODE_ENV=development

# Database Configuration (PostgreSQL URL format)
# Example: postgresql://username:password@localhost:5432/hotelflow?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hotelflow?schema=public"

# Authentication Secrets (Generate secure random values in production)
JWT_ACCESS_SECRET="super-secret-access-token-key-change-in-production"
JWT_REFRESH_SECRET="super-secret-refresh-token-key-change-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Cloud Storage Configuration (Optional - Falls back to local disk storage if undefined)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# CORS Mappings (Comma-separated list of production URLs)
ALLOWED_ORIGINS="https://your-production-web-app.com,http://localhost:5173"
